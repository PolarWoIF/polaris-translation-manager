{
  "name": "polar-translation",
  "productName": "Polar Translation",
  "private": false,
  "version": "1.0.7",
  "type": "module",
  "main": "electron.cjs",
  "scripts": {
    "dev": "vite --port=3000 --host=0.0.0.0",
    "build": "vite build",
    "preview": "vite preview",
    "clean": "node -e \"const fs=require('fs');['dist','dist_electron'].forEach((p)=>fs.rmSync(p,{recursive:true,force:true}));\"",
    "icons:generate": "node scripts/generate-windows-icons.mjs",
    "lint": "tsc --noEmit",
    "validate:content": "node scripts/validate-content.mjs",
    "sync:cloudflare-content": "node scripts/sync-cloudflare-content.mjs",
    "content:secure:prepare": "node scripts/prepare-secure-content.mjs",
    "verify:existing-user-update": "tsx scripts/verify-existing-user-update.ts",
    "electron:dev": "electron .",
    "electron:build": "npm run build && electron-builder --win nsis --x64",
    "build:renderer": "vite build",
    "build:desktop": "npm run icons:generate && npm run build:renderer && electron-builder --win nsis --x64",
    "build:release": "npm run clean && npm run lint && npm run validate:content && npm run verify:existing-user-update && npm run build:desktop",
    "build:exe": "npm run build:desktop",
    "version:check": "node -e \"const v=require('./package.json').version; if(!/^\\d+\\.\\d+\\.\\d+$/.test(v)){throw new Error('Version must be semver x.y.z')}}\""
  },
  "build": {
    "appId": "com.polar.translation",
    "productName": "Polar Translation",
    "asar": true,
    "compression": "maximum",
    "directories": {
      "output": "dist_electron"
    },
    "files": [
      "dist/**/*",
      "electron.cjs",
      "package.json",
      "!backups/**/*",
      "!dist_electron/**/*"
    ],
    "extraResources": [
      {
        "from": "public/assets/red-set/windows/icon.ico",
        "to": "icon.ico"
      }
    ],
    "extraMetadata": {
      "main": "electron.cjs"
    },
    "artifactName": "Polar-Translation-${version}-${arch}.${ext}",
    "win": {
      "executableName": "Polar Translation",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "public/assets/red-set/windows/icon.ico",
      "signAndEditExecutable": true
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Polar Translation",
      "installerIcon": "public/assets/red-set/windows/icon.ico",
      "uninstallerIcon": "public/assets/red-set/windows/icon.ico",
      "installerHeaderIcon": "public/assets/red-set/windows/icon.ico",
      "artifactName": "Polar-Translation-Setup-${version}.${ext}"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "PolarWoIF",
        "repo": "polaris-translation-manager",
        "releaseType": "release"
      }
    ]
  },
  "dependencies": {
    "7zip-bin": "^5.2.0",
    "electron-updater": "^6.6.2",
    "jszip": "^3.10.1",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.14",
    "@types/node": "^22.14.0",
    "@vitejs/plugin-react": "^5.0.4",
    "autoprefixer": "^10.4.21",
    "electron": "^41.2.0",
    "electron-builder": "^26.8.1",
    "png-to-ico": "^3.0.1",
    "tailwindcss": "^4.1.14",
    "terser": "^5.43.1",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0"
  },
  "description": "Polar Translation desktop manager for Arabic game localization patches.",
  "author": "Polar Translation",
  "license": "MIT"
}
