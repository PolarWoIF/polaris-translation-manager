# Remote content source (Cloudflare R2 public JSON file)
VITE_REMOTE_JSON_URL="https://pub-bffc58c40ead4c63a2c4a971e09daf07.r2.dev/translations.json"

# Optional: app update manifest URL (JSON with latestVersion + releaseUrl)
# Example:
# {
#   "latestVersion": "1.0.1",
#   "releaseUrl": "https://github.com/<owner>/<repo>/releases/tag/v1.0.1"
# }
VITE_REMOTE_APP_RELEASE_URL=""

# Optional: GitHub API endpoint fallback for latest release check
# Example:
# VITE_GITHUB_RELEASES_API_URL="https://api.github.com/repos/<owner>/<repo>/releases/latest"
VITE_GITHUB_RELEASES_API_URL=""

# Optional: secure Cloudflare download gateway base URL (Worker endpoint).
# When enabled, installer requests short-lived authorized links from this gateway
# instead of exposing direct public R2 object URLs in the app bundle.
# Example: VITE_DOWNLOAD_GATEWAY_URL="https://downloads.polartranslation.com"
VITE_DOWNLOAD_GATEWAY_URL=""

# If true, installation fails when gateway authorization fails.
# If false, app falls back to direct downloadUrl (compatibility mode).
VITE_DOWNLOAD_GATEWAY_STRICT="false"
