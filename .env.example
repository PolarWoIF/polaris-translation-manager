# Remote content source (Cloudflare Worker content endpoint)
VITE_REMOTE_JSON_URL="https://polar-download-gateway.mdmrksad1ksa.workers.dev/api/content"

# Optional: app update manifest URL (JSON with latestVersion + releaseUrl)
# Example:
# {
#   "latestVersion": "1.0.1",
#   "releaseUrl": "https://github.com/<owner>/<repo>/releases/tag/v1.0.1"
# }
VITE_REMOTE_APP_RELEASE_URL=""

# Optional: GitHub API endpoint fallback for latest release check
# Example:
# VITE_GITHUB_RELEASES_API_URL="https://api.github.com/repos/<owner>/<repo>/releases/latest"
VITE_GITHUB_RELEASES_API_URL=""

# Secure Cloudflare download gateway base URL (Worker endpoint).
VITE_DOWNLOAD_GATEWAY_URL="https://polar-download-gateway.mdmrksad1ksa.workers.dev"

# If true, installation fails when gateway authorization fails.
VITE_DOWNLOAD_GATEWAY_STRICT="true"
